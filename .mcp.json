{
  "mcpServers": {
    "nixos": {
      "command": "nix",
      "args": [
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ],
      "type": "stdio"
    },
    "carl-mcp": {
      "command": "node",
      "args": [
        ".agents/carl/runtime/carl-mcp/index.js"
      ],
      "type": "stdio"
    }
  }
}
